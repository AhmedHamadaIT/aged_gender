# ============================================
# YOLO Detection — Configuration
# ============================================

# ── Cameras ──────────────────────────────────
# Number of cameras
NUM_CAMERAS=2

# RTSP URL per camera (CAMERA_1_URL, CAMERA_2_URL, ...)
CAMERA_1_URL=rtsp://admin:Aa112233@10.0.3.71:554/Streaming/channels/1101
CAMERA_2_URL=rtsp://admin:Aa112233@10.0.3.71:554/Streaming/channels/1101

# ── Model ────────────────────────────────────
YOLO_MODEL=./models/yolov8n.engine
CONF_THRESHOLD=0.35
FILTER_CLASSES=
DEVICE=0

# ── Inference resolution ─────────────────────
WIDTH=1280
HEIGHT=720

# ── Output ───────────────────────────────────
SAVE_OUTPUT=True
OUTPUT_DIR=./outputs
MAX_OUTPUT_FRAMES=

# __ Init _____________________________________ 
PIPELINE=detector

# ── EyeGo API (optional) ─────────────────────
API_BASE_URL=http://localhost:8000