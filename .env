# ── Pipeline ─────────────────────────────────
# Comma-separated services to run on each frame, in order
# Available: detector, age_gender
PIPELINE=detector,age_gender


# ── Detection model ──────────────────────────
YOLO_MODEL=./models/yolov8n.pt
CONF_THRESHOLD=0.35
FILTER_CLASSES=
DEVICE=cpu

# ── Age & Gender model ────────────────────────
AGE_GENDER_MODEL=./models/best_aged_gender_6.onnx
AGE_GENDER_PADDING=10

# ── Inference resolution ─────────────────────
WIDTH=1280
HEIGHT=720

# ── Mood model ───────────────────────────────
MOOD_MODEL=./models/best_mood.onnx

# ── Output ───────────────────────────────────
SAVE_OUTPUT=True
OUTPUT_DIR=./outputs
MAX_OUTPUT_FRAMES=
