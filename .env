# ── Pipeline ─────────────────────────────────
# Comma-separated services to run on each frame, in order
# Available: detector, age_gender
PIPELINE=detector,age_gender


# ── Detection model ──────────────────────────
YOLO_MODEL=./models/yolov8n.engine
CONF_THRESHOLD=0.35
FILTER_CLASSES=
DEVICE=0

# ── Age & Gender model ────────────────────────
AGE_GENDER_MODEL=./models/best_aged_gender_6.onnx
AGE_GENDER_PADDING=10

# ── PPE model ────────────────────────
PPE_MODEL=./models/best_ppe.onnx
PPE_PADDING=10
PPE_CONF=0.25
PPE_IOU=0.45

# ── Inference resolution ─────────────────────
WIDTH=1280
HEIGHT=720

# ── Output ───────────────────────────────────
SAVE_OUTPUT=True
OUTPUT_DIR=./outputs
MAX_OUTPUT_FRAMES=
