# ── Pipeline ─────────────────────────────────
# Comma-separated services to run on each frame, in order
# Available: detector, age_gender, mood, cashier
PIPELINE=detector,age_gender


# ── Detection model ──────────────────────────
YOLO_MODEL=./models/yolov8n.engine
CONF_THRESHOLD=0.35
FILTER_CLASSES=
DEVICE=0

# ── Age & Gender model ────────────────────────
AGE_GENDER_MODEL=./models/best_aged_gender_6.onnx
AGE_GENDER_PADDING=10

# ── PPE model ────────────────────────
PPE_MODEL=./models/best_ppe.onnx
PPE_PADDING=10
PPE_CONF=0.25
PPE_IOU=0.45

# ── Inference resolution ─────────────────────
WIDTH=1280
HEIGHT=720

# ── Mood model ───────────────────────────────
MOOD_MODEL=./models/best_mood.onnx

# ── Cashier Drawer monitor ────────────────────
CASHIER_MODEL=./models/best_cashier.onnx
CASHIER_CONFIG=./config/cashier_zones.yaml
CASHIER_EVIDENCE_DIR=./evidence/cashier
CASHIER_CAMERA_ID=cam
CASHIER_CONF_PERSON=0.50
CASHIER_CONF_DRAWER=0.45
CASHIER_CONF_CASH=0.50
CASHIER_DRAWER_MAX_SEC=30
CASHIER_WAIT_MAX_SEC=30
CASHIER_PROXIMITY_IOU=0.05
CASHIER_RELOAD_INTERVAL=60
CASHIER_LOG_MAX=5000

# ── Output ───────────────────────────────────
SAVE_OUTPUT=True
OUTPUT_DIR=./outputs
MAX_OUTPUT_FRAMES=
